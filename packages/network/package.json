{
  "name": "@technical-1/network",
  "version": "1.0.0",
  "description": "Request blocking, response capture, and network throttling / offline emulation for Puppeteer pages.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run"
  },
  "dependencies": {
    "@technical-1/core": "workspace:^"
  },
  "peerDependencies": {
    "puppeteer-core": ">=22 <25"
  },
  "devDependencies": {
    "puppeteer-core": "^24.4.0"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Technical-1/Puppeteer-Packages.git",
    "directory": "packages/network"
  },
  "publishConfig": {
    "access": "public"
  }
}
