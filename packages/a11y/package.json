{
  "name": "@technical-1/a11y",
  "version": "1.0.0",
  "description": "Accessibility (AX) tree snapshot and role/name query helpers for Puppeteer pages — typed, DI-logger, PptrKitError.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Technical-1/Puppeteer-Packages.git",
    "directory": "packages/a11y"
  },
  "type": "module",
  "sideEffects": false,
  "engines": { "node": ">=18" },
  "files": ["dist"],
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run"
  },
  "dependencies": { "@technical-1/core": "workspace:^" },
  "peerDependencies": { "puppeteer-core": ">=22 <25" },
  "devDependencies": { "puppeteer-core": "^24.4.0" },
  "publishConfig": { "access": "public" }
}
