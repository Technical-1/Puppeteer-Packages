{
  "name": "@technical-1/retry",
  "version": "0.0.0",
  "description": "Generic backoff/retry wrappers keyed off the @technical-1/core retryable error contract",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Technical-1/Puppeteer-Packages.git",
    "directory": "packages/retry"
  },
  "type": "module",
  "sideEffects": false,
  "files": ["dist"],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run"
  },
  "dependencies": {
    "@technical-1/core": "workspace:^"
  }
}
