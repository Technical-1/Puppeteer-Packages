{
  "name": "@technical-1/session",
  "version": "0.0.0",
  "description": "Capture and restore browser session state — cookies, localStorage, sessionStorage — with a label-keyed store for multi-account workflows.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run"
  },
  "dependencies": {
    "@technical-1/core": "workspace:^"
  },
  "peerDependencies": {
    "puppeteer-core": ">=22 <25"
  },
  "devDependencies": {
    "puppeteer-core": "^24.4.0"
  },
  "sideEffects": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Technical-1/Puppeteer-Packages.git",
    "directory": "packages/session"
  },
  "publishConfig": { "access": "public" }
}
