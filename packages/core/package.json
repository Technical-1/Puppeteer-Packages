{
  "name": "@technical-1/core",
  "version": "0.0.0",
  "description": "Shared types, typed error hierarchy, and Logger interface for the @technical-1 Puppeteer suite",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": ["dist"],
  "exports": {
    ".": {
